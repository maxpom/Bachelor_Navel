<?xml version="1.0"?>
<robot name="navel_robot">

  <link name="base_link"/>

  <link name="left_wheel_link">
  </link>

  <joint name="left wheel" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.165 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel_link">
  </link>

  <joint name="right wheel" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
  
    <origin xyz="0 -0.165 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="lidar_left_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
    </visual>
  </link>

  <joint name="lidar_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_left_link"/>
    <origin xyz="0.10 0.05 0.20" rpy="0 0 0"/>
  </joint>

  <link name="lidar_right_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
    </visual>
  </link>

  <joint name="lidar_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_right_link"/>
    <origin xyz="0.10 -0.05 0.20" rpy="0 0 0"/>
  </joint>

  <link name="head_camera_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </visual>
  </link>

  <joint name="head_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="head_camera_link"/>
    <origin xyz="0.15 0.00 0.40" rpy="0 0 0"/>
  </joint>

  <webots>
    <device reference="left wheel sensor" type="PositionSensor">
      <ros>
        <topicName>/left_wheel_sensor</topicName>
        <alwaysOn>true</alwaysOn>
      </ros>
    </device>

    <device reference="right wheel sensor" type="PositionSensor">
      <ros>
        <topicName>/right_wheel_sensor</topicName>
        <alwaysOn>true</alwaysOn>
      </ros>
    </device>

    <device reference="left wheel" type="RotationalMotor">
      <ros>
        <topicName>/left_wheel/velocity</topicName>
      </ros>
    </device>

    <device reference="right wheel" type="RotationalMotor">
      <ros>
        <topicName>/right_wheel/velocity</topicName>
      </ros>
    </device>

    <device reference="head_camera" type="Camera">
      <ros>
        <topicName>/head_camera</topicName>
        <frameName>head_camera_link</frameName>
        <alwaysOn>true</alwaysOn>
      </ros>
    </device>

    <device reference="lidar_right" type="Lidar">
      <ros>
        <topicName>/lidar_right</topicName>
        <frameName>lidar_right_link</frameName>
        <publishLaserScan>true</publishLaserScan>
        <alwaysOn>true</alwaysOn>
      </ros>
    </device>

    <device reference="lidar_left" type="Lidar">
      <ros>
        <topicName>/lidar_left</topicName>
        <frameName>lidar_left_link</frameName>
        <publishLaserScan>true</publishLaserScan>
        <alwaysOn>true</alwaysOn>
      </ros>
    </device>

    <plugin type="my_package.pedestrian_driver.PedestrianDriver">
      <robot_name>person_1</robot_name>
    </plugin>
  </webots>

</robot>